# Snap Thai Hub — environment configuration
# Copy this file to `.env.local` and fill in real values.

# Admin dashboard password (required to access /admin)
ADMIN_PASSWORD=change-me

# Stripe — leave empty to run in demo mode (payments are simulated).
# Get keys at https://dashboard.stripe.com/apikeys
# Use sk_live_/whsec_ values for real payments, sk_test_ for testing.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Canonical site URL for Stripe success/cancel redirects (optional —
# defaults to the incoming request origin). Set to your live domain.
# APP_URL=https://www.snapthaihub.com

# Where the SQLite DB and uploaded photos are stored. Defaults to ./data
# locally. In production point this at a persistent disk (Render sets it to
# /var/data via render.yaml) so orders and uploads survive redeploys.
# DATA_DIR=/var/data

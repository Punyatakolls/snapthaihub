# Snap Thai Hub — environment configuration
# Copy this file to `.env.local` and fill in real values.

# Admin dashboard password (required to access /admin)
ADMIN_PASSWORD=change-me

# Stripe — leave empty to run in demo mode (payments are simulated).
# Get keys at https://dashboard.stripe.com/apikeys
# Use sk_live_/whsec_ values for real payments, sk_test_ for testing.
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Email (Resend) — leave empty to disable email (the app still works,
# notifications are just skipped). Get a key at https://resend.com/api-keys
# RESEND_API_KEY=re_...
# EMAIL_FROM must use a domain you've verified in Resend.
# EMAIL_FROM=Snap Thai Hub <hello@snapthaihub.com>
# OWNER_EMAIL receives new-order and payment alerts.
# OWNER_EMAIL=you@example.com

# Where the SQLite DB and uploaded photos are stored. Defaults to ./data
# locally. In production point this at a persistent disk (Render sets it to
# /var/data via render.yaml) so orders and uploads survive redeploys.
# DATA_DIR=/var/data
